/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Pipeline Nextflow config file 
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

executor {
    name = 'slurm'
    
    // Keep polling relaxed to avoid being throttled/killed by the HPC head node
    pollInterval      = '30 sec'
    queueStatInterval = '5 min'

    // Wait up to 30 minutes for the shared filesystem to report the exit code
    // (Crucial for heavy I/O jobs dealing with 100GB+ files)
    exitReadTimeout   = '30 min'

    // Prevent Nextflow from submitting too many jobs at the exact same time
    submitRateLimit   = '10 sec'
    queueSize         = 5
}

process {
    // Use symlinks for input files (not copies)
    stageInMode = 'symlink'
    
    // Move output files out of work directory (don't copy)
    stageOutMode = 'move'
    
    scratch = false
    
    errorStrategy = { task.exitStatus == 137 ? 'retry' : 'finish' }
    maxRetries = 2
    maxErrors = -1
}
// ============================================================================

params {
    // Input options
    input         = null
    genome        = null
    gencode_gtf   = null
    outdir        = 'results'
    data_type     = "pacbio_ccs"
    min_reads     = 5
    compress      = true

    // Single-cell input
    sc_mode      = 'tenX_v3'
    barcode_tag  = 'CB'
    umi_tag      = 'UB'
    sc_platform  = 'ONT' // or 'PACBIO'
    sc_chemistry = '10x3v3'

    // Cluster Limits
    max_memory    = 300.GB
    max_time      = 72.h
}

// Load base.config by default for all pipelines
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

profiles {
    cluster {
        process.executor = 'slurm'
        process.clusterOptions = "-A gvo00082" 
    }
    
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
    }
}

// Container configurations
apptainer {
    enabled    = true
    autoMounts = true
    cacheDir   = "${System.getenv('VSC_SCRATCH_VO_USER')}/apptainer_cache"
    runOptions = "-B /tmp -B ${System.getenv('VSC_DATA_VO_USER')} -B ${System.getenv('VSC_SCRATCH_VO_USER')}"
    pullTimeout = '45 min'
}

// OOM Kill Prevention: Force Apptainer to use scratch drive for temp files
env {
    APPTAINER_CACHEDIR = "${System.getenv('VSC_SCRATCH_VO_USER')}/apptainer_cache"
    APPTAINER_TMPDIR   = "${System.getenv('VSC_SCRATCH_VO_USER')}/apptainer_tmp"
}

// Function to ensure resource requirements don't exceed cluster limits
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            def maxMem = params.max_memory as nextflow.util.MemoryUnit
            return obj > maxMem ? maxMem : obj
        } catch (all) {
            println "### ERROR ### Max memory '${params.max_memory}' invalid, using $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            def maxTime = params.max_time as nextflow.util.Duration
            return obj > maxTime ? maxTime : obj
        } catch (all) {
            println "### ERROR ### Max time '${params.max_time}' invalid, using $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj, params.max_cpus as int)
        } catch (all) {
            println "### ERROR ### Max cpus '${params.max_cpus}' invalid, using $obj"
            return obj
        }
    }
}

// Reporting Configuration
trace {
    enabled = true
    file    = 'trace.txt'
    overwrite = true
}
report {
    enabled = true
    file    = 'report.html'
    overwrite = true
}
timeline {
    enabled = true
    file    = 'timeline.html'
    overwrite = true
}
