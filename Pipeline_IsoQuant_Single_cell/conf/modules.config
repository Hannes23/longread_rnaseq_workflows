process {
    // Default publishDir for all processes
    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: 'move',
        saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
    ]

    // ============================================================================
    // LIGHTWEIGHT PROCESSES 
    // ============================================================================
    
    withName: 'FASTQC' {
        container = 'https://depot.galaxyproject.org/singularity/fastqc:0.12.1--hdfd78af_0'
        // QC reports are small, keep defaults
    }

    // ============================================================================
    // FLEXIPLEX: Barcode discovery/filtering/demux
    // ============================================================================
    
    withName: 'FLEXIPLEX_DISCOVER' {
        container = 'file:///scratch/gent/vo/000/gvo00082/vsc48905/apptainer_cache/flexiplex_pigz.sif'
        publishDir = [ enabled: false ]  
    }

    withName: 'FLEXIPLEX_FILTER' {
        container = 'file:///scratch/gent/vo/000/gvo00082/vsc48905/apptainer_cache/flexiplex_pigz.sif'
        publishDir = [ enabled: false ]  
    }

    withName: 'FLEXIPLEX_DEMUX' {
        container = 'file:///scratch/gent/vo/000/gvo00082/vsc48905/apptainer_cache/flexiplex_pigz.sif'
        
        // ← CRITICAL: Use scratch for demux (creates large temp FASTQ)
        scratch = '/tmp'
        stageOutMode = 'move'
        
        // Save demux output (needed for alignment)
        publishDir = [
            path: { "${params.outdir}/demux" },
            pattern: "*.demultiplexed.fastq*",
            mode: 'symlink',
            enabled: true
        ]
    }

    // ============================================================================
    // MINIMAP2
    // ============================================================================
    
    withName: 'MINIMAP2' {
        container = 'https://depot.galaxyproject.org/singularity/mulled-v2-66534bcbb7031a148b13e2ad42583020b9cd25c4:3161f532a5ea6f1dec9be5667c9efc2afdac6104-0'
        ext.args = '-ax splice -uf --secondary=no -MD'
    
        // ← CRITICAL FIX #1: Use /tmp for SAM files (they're HUGE but temporary)
        scratch = '/tmp'
        
        // ← CRITICAL FIX #2: Move BAM out of work dir immediately
        stageOutMode = 'move'
        
        // ← CRITICAL FIX #3: Only publish final BAM, NOT SAM
        publishDir = [
            [
                path: { "${params.outdir}/alignment/bams" },
                pattern: "*.sorted.bam",
                mode: 'symlink',
                enabled: true   // ← Keep final BAMs (needed for TAG_BAM & downstream)
            ],
            [
                path: { "${params.outdir}/alignment/bams" },
                pattern: "*.sorted.bam.bai",
                mode: 'sameymlink',
                enabled: true
            ],
            [
                path: { "${params.outdir}/alignment" },
                pattern: "*.sam",
                enabled: false  // ← **DO NOT SAVE SAM FILES** (50GB each!)
            ]
        ]
    }

    // ============================================================================
    // TAG_BAM: Injects barcode/UMI tags 
    // ============================================================================
    
    withName: 'TAG_BAM' {
        container = 'https://depot.galaxyproject.org/singularity/mulled-v2-295c3b1e30b1b8b8cae86c1033ba99e7b63674d6:2f4c558dbcac0618112a14d10e44a4d5a69ba3d8-0'
        
        // Don't save intermediate tagged BAMs (only needed for merge)
        publishDir = [ enabled: false ]
    }

    // ============================================================================
    // SAMTOOLS_MERGE: Merges per-sample chunks 
    // ============================================================================
    
    withName: 'SAMTOOLS_MERGE' {
        container = 'https://depot.galaxyproject.org/singularity/mulled-v2-295c3b1e30b1b8b8cae86c1033ba99e7b63674d6:2f4c558dbcac0618112a14d10e44a4d5a69ba3d8-0'
        
        // Use scratch for merge operations
        scratch = '/tmp'
        stageOutMode = 'move'
        
        // Don't save merged BAM to results (only for IsoQuant input)
        publishDir = [ enabled: false ]
    }

    // ============================================================================
    // ISOQUANT: Quantification (main analysis output)
    // ============================================================================
    
    withName: 'ISOQUANT' {
        container = 'file:///scratch/gent/vo/000/gvo00082/vsc48905/apptainer_cache/isoquant_v3.12.2.sif'
        
        // Use scratch for IsoQuant temp files
        scratch = '/tmp'
        stageOutMode = 'move'
        
        // Save IsoQuant output (GTF, counts needed for SQANTI3)
        publishDir = [
            path: { "${params.outdir}/isoquant" },
            pattern: "isoquant_out/**",
            mode: 'symlink',
            enabled: true
        ]
    }

    // ============================================================================
    // SQANTI3: Annotation QC (main analysis output)
    // ============================================================================
    
    withName: 'SQANTI3' {
        container = "${VSC_SCRATCH_VO_USER}/apptainer_cache/sqanti3_v5.5.4.sif"
        
        // Use scratch for SQANTI3 operations
        scratch = '/tmp'
        stageOutMode = 'move'
        
        // Save essential SQANTI3 outputs (needed for filtering & analysis)
        publishDir = [
            [
                path: { "${params.outdir}/sqanti3" },
                pattern: "sqanti_out/**",
                mode: 'move',
                enabled: true   // ← Keep for filtering & analysis
            ]
        ]
    }

    // ============================================================================
    // SQANTI3_FILTER: Final filtering (produces final outputs)
    // ============================================================================
    
    withName: 'SQANTI3_FILTER' {
        container = "${VSC_SCRATCH_VO_USER}/apptainer_cache/sqanti3_v5.5.4.sif"
        
        // Use scratch for filtering
        scratch = '/tmp'
        stageOutMode = 'move'
        
        // Save filtered outputs (these are the final analysis files)
        publishDir = [
            [
                path: { "${params.outdir}/sqanti3_filter" },
                pattern: "filter_output/**",
                mode: 'move',
                enabled: true   // ← Final output
            ]
        ]
    }
}
