/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Pipeline Nextflow config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/
cleanup = true // Automatically delete intermediate files on success

executor {
    name = 'pbs'
    
    // Slow down polling so the Gallade head node doesn't block Nextflow
    pollInterval = '30 sec'
    queueStatInterval = '5 min'
    
    // THE FIX: Wait 30 minutes before assuming an UNKNOWN job is dead
    exitReadTimeout = '30 min' 
    
    // Prevent Nextflow from submitting too many jobs at the exact same time
    submitRateLimit = '10 sec'
}


params {
    // Input options
    input         = null
    genome        = null
    gencode_gtf   = null
    outdir        = 'results'
    platform      = "SequelII"
    min_reads     = 5

    // Cluster Limits
    max_memory    = 300.GB
    max_time      = 72.h
}

// Load base.config by default for all pipelines
includeConfig 'conf/base.config'
includeConfig 'conf/modules.config'

profiles {
    cluster {
        process.executor = 'pbs'
        process.clusterOptions = "-A gvo00082" 
    }
    
    debug {
        dumpHashes              = true
        process.beforeScript    = 'echo $HOSTNAME'
        cleanup                 = false
    }
}

// Container configurations
apptainer {
    enabled    = true
    autoMounts = true
    cacheDir   = "${System.getenv('VSC_SCRATCH_VO_USER')}/apptainer_cache"
    runOptions = "-B /tmp -B ${System.getenv('VSC_DATA_VO_USER')} -B ${System.getenv('VSC_SCRATCH_VO_USER')}"
}

// ---> THE OOM KILL FIX <---
env {
    // Forces Apptainer to use the TB-scale scratch drive for temporary layer extraction
    // instead of the Head Node's RAM-backed /tmp drive.
    APPTAINER_CACHEDIR = "${System.getenv('VSC_SCRATCH_VO_USER')}/apptainer_cache"
    APPTAINER_TMPDIR   = "${System.getenv('VSC_SCRATCH_VO_USER')}/apptainer_tmp"
}



// Function to ensure resource requirements don't go beyond cluster limits
def check_max(obj, type) {
    if (type == 'memory') {
        try {
            def maxMem = params.max_memory as nextflow.util.MemoryUnit
            return obj > maxMem ? maxMem : obj
        } catch (all) {
            println "### ERROR ### Max memory '${params.max_memory}' invalid, using $obj"
            return obj
        }
    } else if (type == 'time') {
        try {
            def maxTime = params.max_time as nextflow.util.Duration
            return obj > maxTime ? maxTime : obj
        } catch (all) {
            println "### ERROR ### Max time '${params.max_time}' invalid, using $obj"
            return obj
        }
    } else if (type == 'cpus') {
        try {
            return Math.min(obj, params.max_cpus as int)
        } catch (all) {
            println "### ERROR ### Max cpus '${params.max_cpus}' invalid, using $obj"
            return obj
        }
    }
}

// Reporting Configuration
trace {
    enabled = true
    file    = 'trace.txt'
    overwrite = true
}
report {
    enabled = true
    file    = 'report.html'
    overwrite = true
}
timeline {
    enabled = true
    file    = 'timeline.html'
    overwrite = true
}