/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    UGENT HPC (SHINX) - SELF-ADAPTIVE OOM-AWARE CONFIG
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

params {
    max_memory = 360.GB
    max_cpus   = 192
    max_time   = 72.h

    /*
    --------------------------------------------------------------------
        STARTING MEMORY PROFILES (LEARNING SEED)
    --------------------------------------------------------------------
    */
    process_memory_profile = [
        'ISOQUANT'    : 8.GB,
        'ISOQUANT_DB' : 1.GB
    ]
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    EXECUTOR (PBS)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

executor {
    name = 'pbs'
    pollInterval      = '1 min'
    queueStatInterval = '10 min'
    exitReadTimeout   = '30 min'
    submitRateLimit   = '5 sec'
    queueSize         = 11
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    APPTAINER
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

apptainer {
    enabled = true
    autoMounts = true

    cacheDir = "${System.getenv('VSC_SCRATCH_VO_USER')}/apptainer_cache"

    runOptions = """
        --cleanenv \
        -B /tmp \
        -B ${System.getenv('VSC_DATA_VO_USER')} \
        -B ${System.getenv('VSC_SCRATCH_VO_USER')}
    """
}

env {
    APPTAINER_CACHEDIR = "${System.getenv('VSC_SCRATCH_VO_USER')}/apptainer_cache"
    APPTAINER_TMPDIR   = "${System.getenv('VSC_SCRATCH_VO_USER')}/apptainer_tmp"
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    OOM DETECTION
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

def is_oom(task) {
    return task.exitStatus in [137, 143]
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    MEMORY PROFILE ACCESSOR
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

def get_base_memory(task) {
    return params.process_memory_profile[task.process] ?: 2.GB
}

/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    PROCESS CONFIG (SELF-ADAPTIVE CORE)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {

    executor = 'pbs'
    clusterOptions = "-A gvo00082"

    /*
    --------------------------------------------------------------------
        CPU SCALING (SAFE FOR SHINX)
    --------------------------------------------------------------------
    */

    cpus = {
        task.attempt == 1 ? 8 :
        task.attempt == 2 ? 16 : 32
    }

    /*
    --------------------------------------------------------------------
        MEMORY: SELF-LEARNING + OOM-AWARE
    --------------------------------------------------------------------
    */

    memory = {

        def base = get_base_memory(task)

        // CPU scaling component
        def cpu_component = task.cpus * 1.2.GB

        // retry escalation
        def attempt_factor = task.attempt

        // OOM boost
        def oom_factor = is_oom(task) ? 1.5 : 1.0

        return (base + cpu_component) * attempt_factor * oom_factor
    }

    /*
    --------------------------------------------------------------------
        TIME SCALING
    --------------------------------------------------------------------
    */

    time = {
        task.attempt == 1 ? 4.h :
        task.attempt == 2 ? 12.h : 24.h
    }

    /*
    --------------------------------------------------------------------
        PBS MEMORY ENFORCEMENT (CRITICAL)
    --------------------------------------------------------------------
    */

    clusterOptions = {
        def mem_mb = task.memory ? task.memory.toMega() : 4000

        return "-A gvo00082 " +
               "-l mem=${mem_mb}mb " +
               "-l select=1:ncpus=${task.cpus}:mem=${mem_mb}mb"
    }

    /*
    --------------------------------------------------------------------
        OOM-AWARE RETRY STRATEGY
    --------------------------------------------------------------------
    */

    errorStrategy = { task ->
        is_oom(task) ? 'retry' : 'terminate'
    }

    maxRetries = 2
    maxErrors  = -1

    /*
    --------------------------------------------------------------------
        OBSERVABILITY
    --------------------------------------------------------------------
    */

    afterScript = {
        """
        echo "[PROFILE]"
        echo "process=${task.process}"
        echo "exit=${task.exitStatus}"
        echo "attempt=${task.attempt}"
        echo "cpus=${task.cpus}"
        echo "memory=${task.memory}"
        """
    }
}





